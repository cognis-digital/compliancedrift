{
  "kind": "Deployment",
  "metadata": {
    "name": "checkout-service",
    "namespace": "payments"
  },
  "spec": {
    "replicas": 3,
    "template": {
      "spec": {
        "automountServiceAccountToken": true,
        "securityContext": {
          "runAsNonRoot": false,
          "runAsUser": 0,
          "fsGroup": 10001,
          "seccompProfile": {
            "type": "Unconfined"
          }
        },
        "containers": [
          {
            "name": "checkout",
            "image": "registry.internal/checkout:1.9.0-rc1",
            "imagePullPolicy": "IfNotPresent",
            "securityContext": {
              "privileged": true,
              "allowPrivilegeEscalation": true,
              "readOnlyRootFilesystem": false,
              "capabilities": {
                "drop": [
                  "ALL"
                ],
                "add": [
                  "NET_ADMIN",
                  "SYS_ADMIN"
                ]
              }
            }
          }
        ]
      }
    }
  }
}
